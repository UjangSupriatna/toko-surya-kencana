generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  category  String
  unit      String
  buyPrice  Int
  sellPrice Int
  stock     Int      @default(0)
  minStock  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderItems  OrderItem[]
  stockHistory StockHistory[]

  @@index([category])
  @@index([name])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String?
  type      String   @default("DAPUR") // DAPUR, ECERAN, GROSIR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([name])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status      String      @default("PENDING")
  notes       String?
  totalAmount Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  invoice     Invoice?
  payments    Payment[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
  subtotal  Int
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id])
  status        String   @default("UNPAID")
  ppnRate       Int      @default(11)
  ppnAmount     Int      @default(0)
  totalAmount   Int
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model Payment {
  id            String   @id @default(cuid())
  paymentNumber String   @unique
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Int
  method        String   @default("TRANSFER") // CASH, TRANSFER
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())

  @@index([date])
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Int
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([category])
}

model StockHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  type      String   // IN, OUT
  quantity  Int
  note      String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}
